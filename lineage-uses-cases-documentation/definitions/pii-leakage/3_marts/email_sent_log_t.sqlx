config { 
    type: "table",
    schema: "documentation_pii_leakage",
    tags: ["pii-leakage"],
}

SELECT
    t1.order_id,
    t1.user_email,
    CURRENT_TIMESTAMP() AS sent_timestamp
FROM
    ${ref("order_status_update")} AS t1
INNER JOIN
    ${ref("order_details_v")} AS t2 ON t1.order_id = t2.order_id