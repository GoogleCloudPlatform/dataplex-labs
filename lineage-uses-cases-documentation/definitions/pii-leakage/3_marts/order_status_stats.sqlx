config { 
    type: "view",
    schema: "documentation_pii_leakage",
    tags: ["pii-leakage"],
}

SELECT
    t1.order_status,
    t2.user_email,
    t2.user_orders,
    t1.total_orders
FROM
    ${ref("status_counts_base_v")} AS t1
INNER JOIN
    ${ref("status_counts_by_user_v")} AS t2
    ON t1.order_status = t2.order_status