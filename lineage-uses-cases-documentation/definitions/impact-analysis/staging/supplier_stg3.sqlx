config { 
  type: "table",
  schema: "documentation_impact_analysis",
  tags: ["impact-analysis"]
}

SELECT
    npi, nppes_credentials, medicare_participation_indicator, hcpcs_code,
    hcpcs_description, average_submitted_chrg_amt, average_medicare_payment_amt,
    SAFE_DIVIDE(average_medicare_payment_amt, average_submitted_chrg_amt) AS payment_ratio
FROM
  ${ref("supplier_stg1")}
