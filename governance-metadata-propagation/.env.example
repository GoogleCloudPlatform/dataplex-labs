GOOGLE_REDIRECT_URI=http://localhost:7860/google_callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: Writable BigQuery dataset for storing business glossary embeddings cache.
# Essential when scanning read-only datasets where the steward lacks write permissions.
# GLOSSARY_CACHE_DATASET_ID=your_cache_dataset_id

# Optional: Custom table name for glossary embeddings cache (defaults to glossary_embeddings_cache)
# GLOSSARY_CACHE_TABLE_ID=glossary_embeddings_cache